# =============================================================================
# Copier ce fichier vers .env à la racine du projet (ne jamais committer .env)
# =============================================================================

# --- Airflow 3 ---
# Générer une clé Fernet :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=replace_with_your_fernet_key

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_in_production

# UID Linux pour les volumes Airflow (souvent 50000 sous Docker Desktop)
AIRFLOW_UID=50000

# JWT Airflow 3 (changer en production)
AIRFLOW__API_AUTH__JWT_SECRET=replace_with_a_long_random_secret
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# --- Kafka / ingestion (Airflow DAG wikimedia_ingestion) ---
# KAFKA_BOOTSTRAP=kafka:29092
# INGESTION_BATCH_SIZE=300

# --- Dashboard Streamlit ---
# KAFKA_TOPIC=wm.recentchange.raw
# WEBHDFS_BASE=http://namenode:9870/webhdfs/v1
# HDFS_DATA_ROOT=/data/wikimedia
# AIRFLOW_API_BASE=http://airflow-api-server:8080/api/v2
# AIRFLOW_ADMIN_USER=admin
# AIRFLOW_ADMIN_PASSWORD=admin
